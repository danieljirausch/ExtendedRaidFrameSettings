<Ui xmlns="http://www.blizzard.com/wow/ui/">
  <Frame name="ERFSDropdownTemplate" hidden="false" virtual="true">
    <Size x="343" y="32"/>
    <Anchors>
      <Anchor point="TOPLEFT"/>
    </Anchors>
    <Layers>
      <Layer level="ARTWORK">
        <FontString parentKey="Label" text="$text" inherits="GameFontHighlightMedium" justifyH="LEFT">
          <Size x="100"/>
          <Anchors>
            <Anchor point="LEFT"/>
          </Anchors>
        </FontString>
      </Layer>
    </Layers>
    <Frames>
      <Frame parentKey="Dropdown">
        <Size x="225" y="30"/>
        <Anchors>
          <Anchor point="LEFT" relativeKey="$parent.Label" relativePoint="RIGHT" x="-10"/>
        </Anchors>
      </Frame>
    </Frames>
  </Frame>

  <Frame name="ExtendedRaidFrameSettingsDialog" inherits="TranslucentFrameTemplate, ResizeLayoutFrame" parent="EditModeSystemSettingsDialog" frameStrata="DIALOG" frameLevel="200" hidden="true">
    <Size x="300" y="500"/>
    <Anchors>
      <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT"/>
      <Anchor point="TOPRIGHT" relativePoint="BOTTOMRIGHT"/>
    </Anchors>
    <KeyValues>
      <KeyValue key="heightPadding" value="-10" type="number"/>
    </KeyValues>
    <Frames>
      <Frame parentKey="Settings" inherits="VerticalLayoutFrame">
        <Size x="1" y="1"/>
        <KeyValues>
          <KeyValue key="spacing" value="2" type="number"/>
        </KeyValues>
        <Anchors>
          <Anchor point="TOP" relativePoint="TOP" y="-20"/>
        </Anchors>
        <Frames>
          <Frame parentKey="GrowthDropdown" inherits="ERFSDropdownTemplate"/>
        </Frames>
      </Frame>
    </Frames>
  </Frame>
</Ui>
