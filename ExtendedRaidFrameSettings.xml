<Ui xmlns="http://www.blizzard.com/wow/ui/">
  <Frame name="ExtendedRaidFrameSettingsDialog" inherits="TranslucentFrameTemplate, ResizeLayoutFrame" parent="EditModeSystemSettingsDialog" frameStrata="DIALOG" frameLevel="200" hidden="true">
    <Size x="300" y="500"/>
    <Anchors>
      <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT"/>
      <Anchor point="TOPRIGHT" relativePoint="BOTTOMRIGHT"/>
    </Anchors>
    <KeyValues>
      <KeyValue key="heightPadding" value="-10" type="number"/>
    </KeyValues>
    <Frames>
      <Frame parentKey="Settings" inherits="VerticalLayoutFrame">
        <Size x="1" y="1"/>
        <KeyValues>
          <KeyValue key="spacing" value="2" type="number"/>
        </KeyValues>
        <Anchors>
          <Anchor point="TOP" relativePoint="TOP" y="-20"/>
        </Anchors>
        <Frames>
          <Frame name="ERFSReverseOrderSetting">
            <Size x="343" y="32"/>
            <Frames>
              <CheckButton parentKey="Button" inherits="UICheckButtonTemplate">
                <Size x="26" y="26"/>
                <Anchors>
                  <Anchor point="LEFT" x="-5"/>
                </Anchors>
              </CheckButton>
            </Frames>
            <Layers>
              <Layer level="ARTWORK">
                <FontString parentKey="Label" inherits="GameFontHighlightMedium"
                            text="Reverse Order" justifyH="LEFT">
                  <Size x="300" y="32"/>
                  <Anchors>
                    <Anchor point="LEFT" relativeKey="$parent.Button"
                            relativePoint="RIGHT" x="5"/>
                  </Anchors>
                </FontString>
              </Layer>
            </Layers>
          </Frame>
        </Frames>
      </Frame>
    </Frames>
  </Frame>
</Ui>
